{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "godot/human-review-brief.schema.json",
  "title": "Godot-RUP Human Review Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "human_review_brief_format",
    "run_id",
    "module_id",
    "dossier_path",
    "decision_path",
    "graph_path",
    "human_review_plan",
    "what_to_try",
    "quick_test_script",
    "success_signals",
    "failure_signals",
    "scope_boundaries",
    "implementation_map",
    "scene_anchor_map",
    "godot_lifecycle_map",
    "extension_points",
    "evidence_map",
    "open_questions",
    "notes"
  ],
  "properties": {
    "human_review_brief_format": {
      "type": "string",
      "const": "godot_human_review_brief/v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "module_id": {
      "type": "string",
      "minLength": 1
    },
    "dossier_path": {
      "type": "string",
      "minLength": 1
    },
    "decision_path": {
      "type": "string",
      "minLength": 1
    },
    "graph_path": {
      "type": "string",
      "minLength": 1
    },
    "human_review_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "experience_review",
        "tech_lead_review",
        "notes"
      ],
      "properties": {
        "experience_review": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "gates_acceptance",
            "focus_points"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "gates_acceptance": {
              "type": "boolean"
            },
            "focus_points": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "tech_lead_review": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "gates_acceptance",
            "focus_points",
            "godot_learning_goals"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "gates_acceptance": {
              "type": "boolean"
            },
            "focus_points": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "godot_learning_goals": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "what_to_try": {
      "type": "string",
      "minLength": 1
    },
    "quick_test_script": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "instruction"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "instruction": {
            "type": "string",
            "minLength": 1
          },
          "expected_signal": {
            "type": "string"
          }
        }
      }
    },
    "success_signals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failure_signals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope_boundaries": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "implementation_map": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "role"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "scene_anchor_map": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "role"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "godot_lifecycle_map": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "script_path",
          "callbacks",
          "summary"
        ],
        "properties": {
          "script_path": {
            "type": "string",
            "minLength": 1
          },
          "callbacks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "extension_points": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_map": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "proof_rigor",
          "pass_criterion",
          "why_it_matters",
          "source_paths"
        ],
        "properties": {
          "evidence_id": {
            "type": "string",
            "minLength": 1
          },
          "proof_rigor": {
            "type": "string",
            "enum": [
              "smoke",
              "strict"
            ]
          },
          "pass_criterion": {
            "type": "string",
            "minLength": 1
          },
          "why_it_matters": {
            "type": "string",
            "minLength": 1
          },
          "source_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
