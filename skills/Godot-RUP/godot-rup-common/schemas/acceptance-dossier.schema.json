{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "godot/acceptance-dossier.schema.json",
  "title": "Godot-RUP Acceptance Dossier",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "acceptance_dossier_format",
    "run_id",
    "module_id",
    "decision_path",
    "graph_path",
    "module_session_path",
    "integration_branch",
    "integration_checkout",
    "last_integration_commit",
    "evidence_scope_ids",
    "evidence_paths",
    "settlement_paths",
    "integration_paths",
    "checklist_inputs",
    "human_review_plan",
    "pending_risks",
    "notes"
  ],
  "properties": {
    "acceptance_dossier_format": {
      "type": "string",
      "const": "godot_acceptance_dossier/v3"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "module_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_path": {
      "type": "string",
      "minLength": 1
    },
    "graph_path": {
      "type": "string",
      "minLength": 1
    },
    "module_session_path": {
      "type": "string",
      "minLength": 1
    },
    "integration_branch": {
      "type": "string",
      "minLength": 1
    },
    "integration_checkout": {
      "type": "string",
      "minLength": 1
    },
    "last_integration_commit": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_scope_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "settlement_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "integration_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checklist_inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "description",
          "expected_proof_type",
          "expected_proof_rigor",
          "pass_criterion",
          "collection_status",
          "cited_scope_ids",
          "cited_evidence_paths"
        ],
        "properties": {
          "evidence_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "expected_proof_type": {
            "type": "string",
            "enum": [
              "compile",
              "headless",
              "snapshot_round_trip",
              "scene_structure_proof",
              "behavior_proof",
              "code_inspection",
              "data_migration_proof",
              "dispatch_audit",
              "resource_bootstrap_proof",
              "other"
            ]
          },
          "expected_proof_rigor": {
            "type": "string",
            "enum": [
              "smoke",
              "strict"
            ]
          },
          "pass_criterion": {
            "type": "string",
            "minLength": 1
          },
          "collection_status": {
            "type": "string",
            "enum": [
              "present",
              "missing"
            ]
          },
          "cited_scope_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "cited_evidence_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "collection_status": {
                  "const": "present"
                }
              },
              "required": [
                "collection_status"
              ]
            },
            "then": {
              "properties": {
                "cited_scope_ids": {
                  "minItems": 1
                },
                "cited_evidence_paths": {
                  "minItems": 1
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "collection_status": {
                  "const": "missing"
                }
              },
              "required": [
                "collection_status"
              ]
            },
            "then": {
              "properties": {
                "cited_scope_ids": {
                  "maxItems": 0
                },
                "cited_evidence_paths": {
                  "maxItems": 0
                }
              }
            }
          }
        ]
      }
    },
    "human_review_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "experience_review",
        "tech_lead_review",
        "notes"
      ],
      "properties": {
        "experience_review": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "gates_acceptance",
            "focus_points"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "gates_acceptance": {
              "type": "boolean"
            },
            "focus_points": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "gates_acceptance": {
                    "const": true
                  }
                },
                "required": [
                  "gates_acceptance"
                ]
              },
              "then": {
                "properties": {
                  "required": {
                    "const": true
                  }
                }
              }
            }
          ]
        },
        "tech_lead_review": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "gates_acceptance",
            "focus_points",
            "godot_learning_goals"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "gates_acceptance": {
              "type": "boolean"
            },
            "focus_points": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "godot_learning_goals": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "gates_acceptance": {
                    "const": true
                  }
                },
                "required": [
                  "gates_acceptance"
                ]
              },
              "then": {
                "properties": {
                  "required": {
                    "const": true
                  }
                }
              }
            }
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "pending_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
