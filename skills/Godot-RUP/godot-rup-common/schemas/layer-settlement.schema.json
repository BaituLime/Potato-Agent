{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "godot/layer-settlement.schema.json",
  "title": "Godot-RUP Layer Settlement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "settlement_format",
    "run_id",
    "module_id",
    "layer_id",
    "settlement_id",
    "attest_result",
    "gate_result",
    "scope_results",
    "layer_checks_run",
    "covered_evidence_scope_ids",
    "first_blocker",
    "notes"
  ],
  "properties": {
    "settlement_format": {
      "type": "string",
      "const": "godot_layer_settlement/v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "module_id": {
      "type": "string",
      "minLength": 1
    },
    "layer_id": {
      "type": "string",
      "minLength": 1
    },
    "settlement_id": {
      "type": "string",
      "minLength": 1
    },
    "attest_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "authoritative_scope_ids"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "settled",
            "blocked"
          ]
        },
        "authoritative_scope_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "gate_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "next_action",
        "review_scope_ids",
        "integration_ready",
        "acceptance_ready"
      ],
      "properties": {
        "next_action": {
          "type": "string",
          "enum": [
            "review",
            "integrate",
            "ready_for_acceptance",
            "rework_needed",
            "manual_needed",
            "blocked"
          ]
        },
        "review_scope_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "integration_ready": {
          "type": "boolean"
        },
        "acceptance_ready": {
          "type": "boolean"
        }
      }
    },
    "scope_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scope_id",
          "authoritative_status",
          "evidence_summary_path",
          "source_attempt_ids"
        ],
        "properties": {
          "scope_id": {
            "type": "string",
            "minLength": 1
          },
          "authoritative_status": {
            "type": "string",
            "enum": [
              "pass",
              "rework_needed",
              "blocked"
            ]
          },
          "evidence_summary_path": {
            "type": "string",
            "minLength": 1
          },
          "source_attempt_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          }
        }
      }
    },
    "layer_checks_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed"
            ]
          },
          "command": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "covered_evidence_scope_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "first_blocker": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
