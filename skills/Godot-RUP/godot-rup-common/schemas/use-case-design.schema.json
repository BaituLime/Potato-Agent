{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "godot/use-case-design.schema.json",
  "title": "Godot-RUP Use-Case Design Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "use_case_design_index_format",
    "module_id",
    "use_case_design_revision_id",
    "supersedes_use_case_design_revision_id",
    "authoritative_markdown_path",
    "key_use_cases",
    "acceptance_sensitive_claims",
    "out_of_scope_ids",
    "open_question_ids",
    "notes"
  ],
  "properties": {
    "use_case_design_index_format": {
      "type": "string",
      "const": "godot_use_case_design_index/v1"
    },
    "module_id": {
      "type": "string",
      "minLength": 1
    },
    "use_case_design_revision_id": {
      "type": "string",
      "minLength": 1
    },
    "supersedes_use_case_design_revision_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "authoritative_markdown_path": {
      "type": "string",
      "minLength": 1
    },
    "key_use_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "use_case_id",
          "heading",
          "label"
        ],
        "properties": {
          "use_case_id": {
            "type": "string",
            "minLength": 1
          },
          "heading": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "acceptance_sensitive_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "summary",
          "serves_use_case_ids"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "serves_use_case_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "out_of_scope_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "open_question_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
