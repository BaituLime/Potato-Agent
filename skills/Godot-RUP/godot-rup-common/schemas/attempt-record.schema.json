{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "godot/attempt-record.schema.json",
  "title": "Godot-RUP Raw Attempt Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "attempt_format",
    "run_id",
    "module_id",
    "scope_id",
    "attempt_id",
    "scope_kind",
    "producer_skill",
    "status",
    "checkout",
    "branch",
    "slot",
    "changed_files",
    "checks_run",
    "dispatch_audit",
    "artifacts",
    "notes",
    "first_blocker"
  ],
  "properties": {
    "attempt_format": {
      "type": "string",
      "const": "godot_attempt_record/v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "module_id": {
      "type": "string",
      "minLength": 1
    },
    "scope_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt_id": {
      "type": "string",
      "pattern": "^attempt-[0-9]{3}$"
    },
    "scope_kind": {
      "type": "string",
      "enum": [
        "task",
        "craft",
        "proof",
        "review"
      ]
    },
    "producer_skill": {
      "type": "string",
      "enum": [
        "run-task",
        "run-craft",
        "run-proof",
        "run-review"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ready_for_attest",
        "partial",
        "blocked"
      ]
    },
    "checkout": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "slot": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checks_run": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "exit_code",
          "stdout_artifact",
          "stderr_artifact"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "not_run"
            ]
          },
          "command": {
            "type": [
              "string",
              "null"
            ]
          },
          "exit_code": {
            "type": [
              "integer",
              "null"
            ]
          },
          "stdout_artifact": {
            "type": [
              "string",
              "null"
            ]
          },
          "stderr_artifact": {
            "type": [
              "string",
              "null"
            ]
          },
          "summary": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "dispatch_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested_model_tier",
        "requested_reasoningEffort",
        "resolved_model",
        "actual_model",
        "resolved_subagent_type",
        "actual_subagent_type",
        "resolved_reasoningEffort",
        "producer_command",
        "dispatch_mode",
        "dispatch_verified"
      ],
      "properties": {
        "requested_model_tier": {
          "type": "string",
          "enum": [
            "full",
            "mini"
          ]
        },
        "requested_reasoningEffort": {
          "type": "string",
          "enum": [
            "medium",
            "high",
            "xhigh"
          ]
        },
        "resolved_model": {
          "type": "string",
          "minLength": 1
        },
        "actual_model": {
          "type": "string",
          "minLength": 1
        },
        "resolved_subagent_type": {
          "type": "string",
          "minLength": 1
        },
        "actual_subagent_type": {
          "type": "string",
          "minLength": 1
        },
        "resolved_reasoningEffort": {
          "type": "string",
          "enum": [
            "medium",
            "high",
            "xhigh"
          ]
        },
        "producer_command": {
          "type": "string",
          "enum": [
            "godot-rup-task",
            "godot-rup-craft",
            "godot-rup-proof",
            "godot-rup-review"
          ]
        },
        "dispatch_mode": {
          "type": "string",
          "const": "opencode_native_child"
        },
        "dispatch_verified": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "diff",
              "log",
              "stdout",
              "stderr",
              "file",
              "screenshot",
              "other"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "feedback_surface": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "required_by_packet",
        "used_resources",
        "requirement_satisfied"
      ],
      "properties": {
        "required_by_packet": {
          "type": "boolean"
        },
        "used_resources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requirement_satisfied": {
          "type": "boolean"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "handoff_back": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "reason_class",
        "summary"
      ],
      "properties": {
        "reason_class": {
          "type": "string",
          "enum": [
            "packet_insufficient",
            "role_mismatch",
            "broader_planning_change_needed",
            "broader_route_redesign_needed",
            "authority_boundary_reached",
            "other"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "suggested_next_step": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "first_blocker": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
